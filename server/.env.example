# ============================================================
# ExplainMyWebsite — Server Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# Port for the Express server (default: 3001)
PORT=3001

# ---- AI Provider (choose ONE) ----

# Option A: OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Option B: Anthropic (Claude) API Key
# Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Which AI provider to use: "openai" | "anthropic" | "mock"
# Use "mock" for development without spending API credits
AI_PROVIDER=mock

# ---- Fetch Settings ----

# Request timeout in ms when fetching websites (default: 10000 = 10s)
FETCH_TIMEOUT=10000

# ---- CORS Settings ----

# Frontend origin (Vite default)
CLIENT_ORIGIN=http://localhost:5173
